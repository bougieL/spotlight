{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spotlight",
  "version": "0.1.0",
  "identifier": "com.bougie.spotlight",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "spotlight",
        "width": 800,
        "height": 64,
        "decorations": false,
        "transparent": true,
        "center": false,
        "resizable": false,
        "shadow": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' asset://localhost data:; font-src 'self' asset://localhost data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' file: asset://localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "localhost",
      "entitlements": "entitlements.plist",
      "frameworks": []
    }
  }
}
